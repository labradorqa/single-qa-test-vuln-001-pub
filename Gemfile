# Intentionally vulnerable Ruby deps for IVAS QA.
source 'https://rubygems.org'

# Rails 5.2.0 — multiple CVEs (CVE-2018-8048 deserialization, etc.)
gem 'rails', '5.2.0'

# Nokogiri 1.10.4 — multiple CVEs
gem 'nokogiri', '1.10.4'

# devise 4.5.0 — older
gem 'devise', '4.5.0'

# rack 2.0.5 — CVE-2018-16470 DoS
gem 'rack', '2.0.5'

# rubyzip 1.2.1 — Zip Slip (CVE-2018-1000544)
gem 'rubyzip', '1.2.1'

# loofah 2.2.0 — XSS (CVE-2018-8048)
gem 'loofah', '2.2.0'
